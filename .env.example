# captions-cli runtime configuration.
# Everything works fully offline with the default local Whisper (whisper-cpp).
# This file is only needed if you opt into the hosted OpenAI Whisper provider.

# OpenAI Whisper API key — required ONLY when running with `--whisper openai`.
# Get one at https://platform.openai.com/api-keys
# Costs ~$0.006 per audio minute. Leave unset to use local whisper-cpp (free).
OPENAI_API_KEY=
